# Postgres (Neon connection string or local docker)
DATABASE_URL="postgresql://user:pass@localhost:5432/clubbify?schema=public"

# Auth.js
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated email domains allowed to sign in (e.g. "clubbify.test,myschool.edu")
# Used as a fallback when no Organization.emailDomainAllowlist is seeded.
ALLOWED_EMAIL_DOMAINS="clubbify.test"

# Default organization slug used at first run (single-tenant mode)
DEFAULT_ORG_SLUG="default"
